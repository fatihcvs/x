# ====== X / Twitter (OAuth 1.0a — get these from developer.x.com) ======
# Your app needs READ + WRITE permissions.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ====== OpenAI (ChatGPT) — get from platform.openai.com ======
OPENAI_API_KEY=

# ====== Telegram — create a bot with @BotFather, then DM your bot once ======
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat id (message @userinfobot to get it)
TELEGRAM_CHAT_ID=

# ====== Web kontrol paneli (opsiyonel) — boşsa panel kapalı ======
# Panele giriş şifresi. Tanımlarsan http://SUNUCU:PORT adresinde açılır.
DASHBOARD_PASSWORD=
# PORT=3000

# ====== LemonSqueezy (Ödeme Sistemi) ======
# LemonSqueezy Dashboard > Settings > Webhooks bölümünden "Signing Secret" alınır
LEMONSQUEEZY_WEBHOOK_SECRET=
# LemonSqueezy Dashboard > Products > Variant ID'leri
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_VARIANT_ID=
# LemonSqueezy Dashboard > Products > Share > Checkout Link URL'leri
LEMONSQUEEZY_PRO_CHECKOUT_URL=
LEMONSQUEEZY_PREMIUM_CHECKOUT_URL=
